{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "noEmit": false,
    "declaration": true,
    "sourceMap": true,
    "types": ["node", "aws-lambda"]
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
