# services/notifier — env vars consumed by the push-notification service.
#
# Copy to `services/notifier/.env` for local-dev. In production each var
# lands in the Lambda's environment via the deploy pipeline.
#
# `loadConfig()` (`src/config.ts`) requires the two SUPABASE_* vars; the
# rest are optional. Without EXPO_ACCESS_TOKEN the service runs in mock
# mode — push messages are appended to an in-memory log so smokes can
# assert what would have been sent.

# ---------------------------------------------------------------------------
# Supabase (required)
# ---------------------------------------------------------------------------

SUPABASE_URL=http://127.0.0.1:54321

# SECRET — bypasses RLS to read other users' push_tokens for fan-out.
# Settings → API → service_role on hosted. Never commit, never bundle.
SUPABASE_SERVICE_ROLE_KEY=replace-me

# ---------------------------------------------------------------------------
# Webhook auth (optional, recommended for hosted)
# ---------------------------------------------------------------------------

# Shared secret. Configure the same value in pg_net's HTTP headers when
# wiring the Postgres triggers. Local dev: leave unset.
# NOTIFIER_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Expo Push (optional)
# ---------------------------------------------------------------------------

# 'real' or 'mock'. Default: 'mock' (safe — never sends real pushes
# unless explicitly opted in).
# NOTIFIER_MODE=mock

# Project access token. Anonymous Expo Push works for development; setting
# this lifts the rate limit and authenticates the calls.
# expo.dev → Account settings → Access tokens.
# EXPO_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Transport (optional)
# ---------------------------------------------------------------------------

# Read by src/index.ts; defaults to 8082.
# PORT=8082

# pino log level: trace | debug | info | warn | error | fatal. Default info.
# LOG_LEVEL=info
