# services/api — env vars consumed by the Lambda handler.
#
# Copy this file to `services/api/.env` and fill in the values. The api
# server reads `process.env` at call time (see `src/lib/config.ts`), so each
# var only needs to exist when a handler that uses it actually runs.
#
# Local dev: `supabase status` after `supabase start` prints the four
# Supabase values below. Production: take them from the Supabase dashboard
# (Settings → API) and inject via your deploy platform's secret store —
# never commit a filled-in copy of this file.

# ---------------------------------------------------------------------------
# Supabase (required for any authenticated route)
# ---------------------------------------------------------------------------

# Project URL. Local: http://127.0.0.1:54321 ; hosted: https://<ref>.supabase.co
SUPABASE_URL=http://127.0.0.1:54321

# Publishable / anon key. Safe to ship; row-level security enforces access.
# Get from `supabase status` locally, or Settings → API → anon key on hosted.
SUPABASE_ANON_KEY=replace-me

# Service-role key. SECRET — bypasses RLS. Used by handlers that legitimately
# need cross-user reads (e.g. friends accept inserting into the friendships
# table where there's no INSERT policy by design). Never bundle into the
# mobile app. Settings → API → service_role on hosted.
SUPABASE_SERVICE_ROLE_KEY=replace-me

# JWT secret used by the auth middleware to verify access tokens via jose
# (HS256, audience = 'authenticated'). Settings → API → JWT Settings on
# hosted. Local default printed by `supabase status`.
SUPABASE_JWT_SECRET=replace-me

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# Returned in the /_health probe. CI sets this to the commit sha; locally
# falls back to 'dev'.
# SERVICE_VERSION=dev
