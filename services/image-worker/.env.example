# services/image-worker — env vars consumed by the closet-promotion service.
#
# Copy this file to `services/image-worker/.env` for local-dev. In
# production each var lands in the Lambda's environment via the deploy
# pipeline (Render dashboard / SST / Pulumi — TBD by feat/lambdas-deploy).
#
# `loadConfig()` (`src/config.ts`) requires the two SUPABASE_* vars; the
# rest are optional. Without ANTHROPIC_API_KEY + REPLICATE_API_TOKEN the
# worker runs in mock mode — vision tags come from a deterministic stub
# and the "tuned" image is the raw photo re-encoded as WebP. End-to-end
# the row still flips PROCESSING → READY, so the closet UI can be
# exercised without burning provider credits.

# ---------------------------------------------------------------------------
# Supabase (required)
# ---------------------------------------------------------------------------

SUPABASE_URL=http://127.0.0.1:54321

# SECRET — bypasses RLS. Used to read closet-raw, write closet-tuned, and
# update closet_items rows on behalf of the upload owner. Settings → API →
# service_role on hosted. Never commit, never bundle into the mobile app.
SUPABASE_SERVICE_ROLE_KEY=replace-me

# ---------------------------------------------------------------------------
# Webhook auth (optional, recommended for hosted)
# ---------------------------------------------------------------------------

# Shared secret for the Supabase database webhook. Configure the same value
# in the webhook's `x-webhook-secret` header. Local dev: leave unset to
# accept all requests (handy when curling the endpoint directly from the
# smoke).
# IMAGE_WORKER_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# AI providers (optional)
# ---------------------------------------------------------------------------

# Anthropic Claude — vision tagging (name/description/category/colors/...).
# When unset, MockVisionProvider runs.
# console.anthropic.com → Settings → API Keys.
# ANTHROPIC_API_KEY=sk-ant-replace-me

# Replicate — bg-removal + studio-light. Wired but not implemented yet
# (§14 OQ-2 model decision pending). Setting both this AND
# IMAGE_WORKER_MODE=real will throw on the first item; leave unset for now.
# REPLICATE_API_TOKEN=r8_replace-me

# 'real' or 'mock'. Default: 'mock' if no provider keys, otherwise 'real'.
# IMAGE_WORKER_MODE=mock

# ---------------------------------------------------------------------------
# Transport (optional)
# ---------------------------------------------------------------------------

# Read by src/index.ts; defaults to 8090. (8081 is Expo's web port — keep them apart.)
# PORT=8090

# pino log level: trace | debug | info | warn | error | fatal. Default info.
# LOG_LEVEL=info
