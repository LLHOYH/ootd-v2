# Mei mobile — Supabase client config.
#
# Copy this file to `.env` and fill in the values printed by `supabase status`
# after `supabase start`. Both vars must be prefixed `EXPO_PUBLIC_` so Expo
# inlines them into the bundle (process.env access is build-time, not runtime).
#
# Hosted dev / staging / prod each have their own URL + anon key — pull those
# from the Supabase dashboard, or from CI secrets in the deploy pipeline.
# The anon key is safe to ship in the bundle: row-level security
# (supabase/migrations/0002_rls_policies.sql) is what enforces access.

# Local-dev defaults from `supabase start`. The anon key below is the one the
# Supabase CLI prints for the local stack; it is identical across machines and
# has zero auth on hosted projects, so committing it here is fine.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Base URL for the api Lambda's HTTP surface.
#   - Local dev: `pnpm --filter @mei/api serve` boots a local server on 3001.
#   - Hosted: API Gateway URL (e.g. https://api.dev.mei.app).
# When unset, the client falls back to http://127.0.0.1:3001.
EXPO_PUBLIC_API_URL=http://127.0.0.1:3001

# Base URL for the Stella SSE service (the Render-hosted stylist).
#   - Local dev: `pnpm --filter @mei/stylist start` boots a Fastify server on 8080.
#   - Hosted: the Render URL (e.g. https://mei-stylist.onrender.com).
# When unset, the client falls back to http://127.0.0.1:8080.
EXPO_PUBLIC_STYLIST_URL=http://127.0.0.1:8080

# Base URL for the image-worker service. Optional in production: a Postgres
# trigger fires the worker via pg_net, so the mobile client never needs to
# know the URL. Required in local dev because Supabase Storage triggers
# can't reach 127.0.0.1 — the upload flow POSTs the storage webhook
# directly when this is set.
EXPO_PUBLIC_IMAGE_WORKER_URL=http://127.0.0.1:8081
