# Mei — ngrok config (v2 syntax — works on all ngrok 3.x agents).
#
# Two modes; pick one block and delete the other.
#
# Recommended: STATIC SINGLE-TUNNEL (works on the free plan, gives a
# permanent URL that doesn't rotate between sessions).
#
#   1. Sign in at https://dashboard.ngrok.com/get-started/your-authtoken
#      and paste your authtoken below.
#   2. Reserve your free static domain at
#      https://dashboard.ngrok.com/cloud-edge/domains
#      (you'll see one already provisioned for free accounts —
#      something like "horse-witty-fox.ngrok-free.dev").
#   3. Replace REPLACE_ME and the `hostname:` line below.
#   4. Run `pnpm tunnel` (boots the proxy on :8000 and ngrok at once).
#   5. Patch apps/mobile/.env once via `pnpm mobile:target:ngrok-static`
#      — now the env stays put forever; ngrok always serves at the
#      same URL.
#
# v3 note: ngrok v3 config files use `version: "3"` + an `endpoints:`
# block. Some 3.x agents in the wild still only accept v1/v2 config
# even though the binary is 3.x — symptom is the error
#   "unknown version '3'. valid versions are: [1 2]"
# v2 syntax (this file) sidesteps that and works everywhere.

version: "2"
authtoken: REPLACE_ME

tunnels:
  proxy:
    proto: http
    addr: 8000
    # Your reserved domain. v2 calls this `hostname`. Both
    # ngrok-free.dev and custom domains work here.
    hostname: REPLACE_ME.ngrok-free.dev

# ─────────────────────────────────────────────────────────────────────
# Alternative: MULTI-TUNNEL (one tunnel per service).
# Requires a paid ngrok plan (free plan = 1 simultaneous tunnel).
# Use scripts/ngrok-tunnel.sh with this config.
#
#   tunnels:
#     api:
#       proto: http
#       addr: 3001
#     stylist:
#       proto: http
#       addr: 8080
#     image-worker:
#       proto: http
#       addr: 8090
#     notifier:
#       proto: http
#       addr: 8082
