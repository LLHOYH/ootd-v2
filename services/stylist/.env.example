# services/stylist — env vars consumed by the Stella HTTP service.
#
# Copy this file to `services/stylist/.env` for local-dev. Render reads
# the same variable names from its dashboard (`render.yaml` declares them
# with `sync: false` so they must be entered there, not committed).
#
# `loadConfig()` (`src/config.ts`) requires the three SUPABASE_* vars;
# the rest are optional. Without ANTHROPIC_API_KEY (or with
# STELLA_LLM_MODE=mock) the service routes through MockProvider and runs
# end-to-end with no API calls — useful for local dev and CI.

# ---------------------------------------------------------------------------
# Supabase (required)
# ---------------------------------------------------------------------------

SUPABASE_URL=http://127.0.0.1:54321

# SECRET — bypasses RLS. Used to read/write stella_conversations +
# stella_messages on behalf of authenticated callers. Settings → API →
# service_role on hosted. Never commit.
SUPABASE_SERVICE_ROLE_KEY=replace-me

# Used by `lib/auth.ts` to verify the Bearer token (HS256, audience
# 'authenticated'). Settings → API → JWT Settings on hosted.
SUPABASE_JWT_SECRET=replace-me

# ---------------------------------------------------------------------------
# Anthropic (optional)
# ---------------------------------------------------------------------------

# API key with Sonnet access (SPEC §8.1). When unset, MockProvider runs.
# When set, also set STELLA_LLM_MODE=real to actually instantiate the SDK.
# console.anthropic.com → Settings → API Keys.
# ANTHROPIC_API_KEY=sk-ant-replace-me

# 'real' or 'mock'. Default: 'mock' if no key, otherwise 'real'.
# STELLA_LLM_MODE=mock

# ---------------------------------------------------------------------------
# Transport (optional)
# ---------------------------------------------------------------------------

# Read by src/index.ts; defaults to 8080 (Render's expected port).
# PORT=8080

# pino log level: trace | debug | info | warn | error | fatal. Default info.
# LOG_LEVEL=info
