# services/mock-server — env vars (minimal).
#
# The mock server runs entirely in-memory; no real auth, no real DB, no
# external services. Tokens follow the dev convention `Bearer mock_<userId>`.
#
# Copy this file to `services/mock-server/.env` if you want to override
# the defaults; otherwise the server runs without any env at all.

# Listen port. Default: 4000.
# PORT=4000

# pino log level. Default: info.
# LOG_LEVEL=info
